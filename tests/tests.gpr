with "config/tests_config.gpr";
with "../humanize.gpr";
project Tests is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use
     ("tests.adb",
      "locale_audit.adb",
      "perf_smoke.adb",
      "perf_baseline_report.adb");

   package Compiler is
      for Default_Switches ("Ada") use Tests_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatyM120", "-gnatX", "-gnatwU");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Tests;
