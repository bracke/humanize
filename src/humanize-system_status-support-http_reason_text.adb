separate (Humanize.System_Status.Support)
function HTTP_Reason_Text (Code : HTTP_Status_Code) return String is
begin
   case Code is
      when 100 => return "continue";
      when 101 => return "switching protocols";
      when 102 => return "processing";
      when 103 => return "early hints";
      when 200 => return "ok";
      when 201 => return "created";
      when 202 => return "accepted";
      when 203 => return "non-authoritative information";
      when 204 => return "no content";
      when 205 => return "reset content";
      when 206 => return "partial content";
      when 207 => return "multi-status";
      when 208 => return "already reported";
      when 226 => return "im used";
      when 300 => return "multiple choices";
      when 301 => return "moved permanently";
      when 302 => return "found";
      when 303 => return "see other";
      when 304 => return "not modified";
      when 305 => return "use proxy";
      when 307 => return "temporary redirect";
      when 308 => return "permanent redirect";
      when 400 => return "bad request";
      when 401 => return "unauthorized";
      when 402 => return "payment required";
      when 403 => return "forbidden";
      when 404 => return "not found";
      when 405 => return "method not allowed";
      when 406 => return "not acceptable";
      when 407 => return "proxy authentication required";
      when 408 => return "request timeout";
      when 409 => return "conflict";
      when 410 => return "gone";
      when 411 => return "length required";
      when 412 => return "precondition failed";
      when 413 => return "content too large";
      when 414 => return "uri too long";
      when 415 => return "unsupported media type";
      when 416 => return "range not satisfiable";
      when 417 => return "expectation failed";
      when 418 => return "i'm a teapot";
      when 421 => return "misdirected request";
      when 422 => return "unprocessable content";
      when 423 => return "locked";
      when 424 => return "failed dependency";
      when 425 => return "too early";
      when 426 => return "upgrade required";
      when 428 => return "precondition required";
      when 429 => return "too many requests";
      when 431 => return "request header fields too large";
      when 451 => return "unavailable for legal reasons";
      when 500 => return "internal server error";
      when 501 => return "not implemented";
      when 502 => return "bad gateway";
      when 503 => return "service unavailable";
      when 504 => return "gateway timeout";
      when 505 => return "http version not supported";
      when 506 => return "variant also negotiates";
      when 507 => return "insufficient storage";
      when 508 => return "loop detected";
      when 510 => return "not extended";
      when 511 => return "network authentication required";
      when others => return "unknown status";
   end case;
end HTTP_Reason_Text;
